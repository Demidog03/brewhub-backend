    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.4.3",
    "drizzle-orm": "^0.44.6",
    "hono": "^4.9.6",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2"
  }
