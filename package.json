{
  "name": "brewhub-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
